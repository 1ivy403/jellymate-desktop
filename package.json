{
  "name": "jellymate",
  "version": "0.1.0",
  "description": "🪼 A tiny jellyfish that lives on the edge of your screen — a calm, low-distraction desktop companion",
  "main": "src/main.js",
  "author": "JellyMate",
  "license": "MIT",
  "homepage": "https://jellymate-amber.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/1ivy403/jellymate-desktop"
  },
  "keywords": ["desktop", "companion", "electron", "macos", "productivity", "focus", "jellyfish"],
  "scripts": {
    "start": "electron .",
    "test": "node test/renderer.test.js",
    "build": "electron-builder --mac --publish never"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "jsdom": "^29.1.1"
  },
  "build": {
    "appId": "com.jellymate.app",
    "productName": "JellyMate",
    "copyright": "Copyright © 2026 JellyMate",
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "JellyMate 安装",
      "background": "assets/dmg-bg.png",
      "window": { "width": 540, "height": 380 }
    },
    "files": ["src/**/*", "assets/**/*"]
  }
}
