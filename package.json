{
  "name": "jellymate",
  "version": "0.1.0",
  "description": "🪼 屏幕边缘的低打扰陪伴水母",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --publish never"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.jellymate.app",
    "productName": "JellyMate",
    "copyright": "Copyright © 2026 JellyMate",
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "JellyMate 安装",
      "background": "assets/dmg-bg.png",
      "window": { "width": 540, "height": 380 }
    },
    "files": ["src/**/*", "assets/**/*"]
  }
}
